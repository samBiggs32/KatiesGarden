@namespace KatiesGarden.Web.Client.Components
@using KatiesGarden.Web.Client.Constants
@using KatiesGarden.Web.Client.Models

<div id="@Id" class="carousel slide gallery-carousel" style="border-radius: 8px; overflow: hidden;">
    <ol class="carousel-indicators">
        @for (int i = 0; i < Images.Count(); i++)
        {
            <li data-target="#@Id" data-slide-to="@i" class="@(i == 0 ? "active" : "")"></li>
        }
    </ol>
    <div class="carousel-inner">
        @for (int i = 0; i < Images.Count(); i++)
        {
            var image = Images.ElementAt(i);
            var jpegSrc = $"{ImagePaths.GalleryBasePath}{image.FileName}";
            var webpSrc = $"{ImagePaths.GalleryBasePath}{WebpFileName(image.FileName)}";
            <div class="carousel-item @(i == 0 ? "active" : "")">
                <picture>
                    <source srcset="@webpSrc" type="image/webp" />
                    <img class="d-block w-100"
                         loading="@(i == 0 ? "eager" : "lazy")"
                         src="@jpegSrc"
                         alt="@image.Alt" />
                </picture>
                <div class="carousel-caption d-none d-md-block">
                    <h5>@image.Title</h5>
                    <p>@image.Description</p>
                </div>
            </div>
        }
    </div>
    <a class="carousel-control-prev" href="#@Id" role="button" data-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="sr-only">Previous</span>
    </a>
    <a class="carousel-control-next" href="#@Id" role="button" data-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="sr-only">Next</span>
    </a>
</div>

@code {
    [Parameter] public string Id { get; set; } = "carousel";
    [Parameter] public IEnumerable<GalleryImage> Images { get; set; } = [];

    // Derives the WebP filename from the JPEG filename.
    // WebP files are pre-generated at build time alongside the originals.
    private static string WebpFileName(string fileName) =>
        System.IO.Path.ChangeExtension(fileName, ".webp");
}