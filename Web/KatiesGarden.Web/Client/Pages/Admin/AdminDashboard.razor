@page "/admin"
@layout AdminLayout
@using KatiesGarden.Models.Shop

<PageTitle>Dashboard — Admin</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6 font-weight-bold">Dashboard</MudText>

@if (_loading)
{
    <MudGrid>
        @for (int i = 0; i < 4; i++)
        {
            <MudItem xs="12" sm="6" md="3">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="100px" />
            </MudItem>
        }
    </MudGrid>
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-6">
        <MudText>@_error</MudText>
        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="RetryAsync" Class="mt-2">Retry</MudButton>
    </MudAlert>
}
else
{
    <!-- Stat cards -->
    <MudGrid Class="mb-8">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 text-center">
                <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Color="Color.Warning" Size="Size.Large" />
                <MudText Typo="Typo.h4">@_pendingCount</MudText>
                <MudText Typo="Typo.body2">Pending Orders</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 text-center">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
                <MudText Typo="Typo.h4">@_confirmedCount</MudText>
                <MudText Typo="Typo.body2">Active Orders</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 text-center">
                <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h4">@_productCount</MudText>
                <MudText Typo="Typo.body2">Active Products</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 text-center">
                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Success" Size="Size.Large" />
                <MudText Typo="Typo.h4">£@_revenue30d.ToString("F0")</MudText>
                <MudText Typo="Typo.body2">Revenue (30 days)</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <!-- Recent orders -->
        <MudItem xs="12" md="8">
            <MudText Typo="Typo.h6" Class="mb-3">Recent Orders</MudText>
            @if (_recentOrders.Count > 0)
            {
                <MudTable Items="_recentOrders" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Order</MudTh>
                        <MudTh>Customer</MudTh>
                        <MudTh>Total</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.OrderNumber</MudTd>
                        <MudTd>@context.CustomerFirstName @context.CustomerLastName</MudTd>
                        <MudTd>£@context.Total.ToString("F2")</MudTd>
                        <MudTd><MudChip T="OrderStatus" Color="@StatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip></MudTd>
                        <MudTd>@context.CreatedAt.ToString("dd MMM")</MudTd>
                        <MudTd><MudButton Size="Size.Small" Href="@($"/admin/orders/{context.Id}")">View</MudButton></MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No orders yet.</MudText>
            }
        </MudItem>

        <!-- Low stock alert panel -->
        <MudItem xs="12" md="4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" Class="mr-1" />
                Low / No Stock
            </MudText>
            @if (_lowStockProducts.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">All products have sufficient stock.</MudText>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @foreach (var p in _lowStockProducts)
                    {
                        <MudListItem>
                            <MudText Typo="Typo.body2">
                                <strong>@p.Name</strong>
                                @if (!p.IsAvailable)
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Class="ml-1">Unavailable</MudChip>
                                }
                                else if (p.StockQuantity.HasValue)
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Class="ml-1">@p.StockQuantity left</MudChip>
                                }
                            </MudText>
                            <MudButton Size="Size.Small" Href="@($"/admin/products/{p.Id}/edit")">Edit</MudButton>
                        </MudListItem>
                    }
                </MudList>
            }
            <MudButton Href="/admin/products" Variant="Variant.Text" Color="Color.Primary" Class="mt-2" Size="Size.Small">
                View all products →
            </MudButton>
        </MudItem>
    </MudGrid>
}

@code {
    [Inject] AdminOrderService AdminOrderService { get; set; } = null!;
    [Inject] AdminProductService AdminProductService { get; set; } = null!;

    private bool _loading = true;
    private string? _error;
    private int _pendingCount, _confirmedCount, _productCount;
    private decimal _revenue30d;
    private List<OrderSummaryDto> _recentOrders = [];
    private List<ProductSummaryDto> _lowStockProducts = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task RetryAsync()
    {
        _loading = true;
        _error = null;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            var ordersTask = AdminOrderService.GetOrdersAsync();
            var productsTask = AdminProductService.GetProductsAsync();
            await Task.WhenAll(ordersTask, productsTask);

            var orders = ordersTask.Result ?? [];
            var products = productsTask.Result ?? [];

            var cutoff = DateTime.UtcNow.AddDays(-30);
            _pendingCount = orders.Count(o => o.Status == OrderStatus.Pending);
            _confirmedCount = orders.Count(o => o.Status is OrderStatus.Confirmed or OrderStatus.Processing or OrderStatus.ReadyForCollection or OrderStatus.Dispatched);
            _productCount = products.Count(p => p.IsAvailable);
            _revenue30d = orders
                .Where(o => o.CreatedAt >= cutoff && o.Status is OrderStatus.Confirmed or OrderStatus.Processing or OrderStatus.ReadyForCollection or OrderStatus.Dispatched or OrderStatus.Delivered)
                .Sum(o => o.Total);

            _recentOrders = orders.Take(5).ToList();
            _lowStockProducts = products
                .Where(p => !p.IsAvailable || (p.StockQuantity.HasValue && p.StockQuantity <= 3))
                .OrderBy(p => p.StockQuantity ?? -1)
                .Take(8)
                .ToList();
        }
        catch (Exception ex)
        {
            _error = $"Could not load dashboard data: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private static Color StatusColor(OrderStatus status) => status switch
    {
        OrderStatus.Confirmed or OrderStatus.Processing => Color.Success,
        OrderStatus.Pending => Color.Warning,
        OrderStatus.Cancelled or OrderStatus.Refunded => Color.Error,
        _ => Color.Default
    };
}
