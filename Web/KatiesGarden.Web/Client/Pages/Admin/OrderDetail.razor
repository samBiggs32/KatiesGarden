@page "/admin/orders/{Id:guid}"
@layout AdminLayout
@using KatiesGarden.Models.Shop

<PageTitle>Order @(_order?.OrderNumber ?? "…") — Admin</PageTitle>

@if (_loading)
{
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="400px" />
}
else if (_order is null)
{
    <MudAlert Severity="Severity.Error">Order not found.</MudAlert>
}
else
{
    <div class="d-flex align-items-center mb-4">
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/admin/orders" Variant="Variant.Text">Back</MudButton>
        <MudText Typo="Typo.h5" Class="ml-2 font-weight-bold">Order @_order.OrderNumber</MudText>
        <MudChip T="OrderStatus" Color="@StatusColor(_order.Status)" Class="ml-3">@_order.Status</MudChip>
    </div>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard Elevation="2" Class="mb-4">
                <MudCardHeader><MudText Typo="Typo.h6">Customer</MudText></MudCardHeader>
                <MudCardContent>
                    <MudText>@_order.CustomerFirstName @_order.CustomerLastName</MudText>
                    <MudText><a href="mailto:@_order.CustomerEmail">@_order.CustomerEmail</a></MudText>
                    <MudText><a href="tel:@_order.CustomerPhone">@_order.CustomerPhone</a></MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudCard Elevation="2" Class="mb-4">
                <MudCardHeader><MudText Typo="Typo.h6">Delivery</MudText></MudCardHeader>
                <MudCardContent>
                    <MudText><strong>@_order.DeliveryType</strong></MudText>
                    @if (_order.DeliveryAddress is not null)
                    {
                        <MudText>@_order.DeliveryAddress, @_order.DeliveryPostcode</MudText>
                    }
                    @if (_order.CustomerNotes is not null)
                    {
                        <MudText Class="mt-2"><em>Notes: @_order.CustomerNotes</em></MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudCard Elevation="2" Class="mb-4">
        <MudCardHeader><MudText Typo="Typo.h6">Items</MudText></MudCardHeader>
        <MudCardContent>
            <MudTable Items="_order.Lines" Dense="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Product</MudTh>
                    <MudTh>Unit Price</MudTh>
                    <MudTh>Qty</MudTh>
                    <MudTh>Total</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.ProductName</MudTd>
                    <MudTd>£@context.UnitPrice.ToString("F2")</MudTd>
                    <MudTd>@context.Quantity</MudTd>
                    <MudTd>£@context.LineTotal.ToString("F2")</MudTd>
                </RowTemplate>
            </MudTable>
            <div class="mt-3 text-end">
                <MudText>Subtotal: £@_order.Subtotal.ToString("F2")</MudText>
                <MudText>Delivery: £@_order.DeliveryFee.ToString("F2")</MudText>
                <MudText Typo="Typo.h6" Color="Color.Primary">Total: £@_order.Total.ToString("F2")</MudText>
            </div>
        </MudCardContent>
    </MudCard>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard Elevation="2" Class="mb-4">
                <MudCardHeader><MudText Typo="Typo.h6">Update Status</MudText></MudCardHeader>
                <MudCardContent>
                    <MudSelect T="OrderStatus" @bind-Value="_newStatus" Variant="Variant.Outlined" Label="New Status" Class="mb-3">
                        <MudSelectItem Value="OrderStatus.Confirmed">Confirmed</MudSelectItem>
                        <MudSelectItem Value="OrderStatus.Processing">Processing</MudSelectItem>
                        <MudSelectItem Value="OrderStatus.ReadyForCollection">Ready for Collection</MudSelectItem>
                        <MudSelectItem Value="OrderStatus.Dispatched">Dispatched</MudSelectItem>
                        <MudSelectItem Value="OrderStatus.Delivered">Delivered</MudSelectItem>
                        <MudSelectItem Value="OrderStatus.Cancelled">Cancelled</MudSelectItem>
                        <MudSelectItem Value="OrderStatus.Refunded">Refunded</MudSelectItem>
                    </MudSelect>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="UpdateStatusAsync"
                               Disabled="@_updatingStatus">
                        @(_updatingStatus ? "Saving…" : "Update Status")
                    </MudButton>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudCard Elevation="2" Class="mb-4">
                <MudCardHeader><MudText Typo="Typo.h6">Internal Notes</MudText></MudCardHeader>
                <MudCardContent>
                    <MudTextField @bind-Value="_adminNotes" Lines="3" Variant="Variant.Outlined"
                                  Label="Notes (not sent to customer)" Class="mb-3" />
                    <MudButton Variant="Variant.Filled" Color="Color.Default" OnClick="SaveNotesAsync"
                               Disabled="@_savingNotes">
                        @(_savingNotes ? "Saving…" : "Save Notes")
                    </MudButton>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    @if (_order.Status is OrderStatus.Confirmed or OrderStatus.Processing or OrderStatus.ReadyForCollection or OrderStatus.Dispatched or OrderStatus.Delivered)
    {
        <MudCard Elevation="1" Class="mb-4 border border-error">
            <MudCardHeader>
                <MudText Typo="Typo.h6" Color="Color.Error">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1" />
                    Issue Refund
                </MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2" Class="mb-3">
                    Issues a full refund of <strong>£@_order.Total.ToString("F2")</strong> via Stripe
                    and marks this order as Refunded.
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Replay"
                           OnClick="RefundOrderAsync" Disabled="@_refunding">
                    @(_refunding ? "Processing refund…" : "Issue Full Refund")
                </MudButton>
            </MudCardContent>
        </MudCard>
    }
}

@code {
    [Inject] AdminOrderService AdminOrderService { get; set; } = null!;
    [Inject] ISnackbar Snackbar { get; set; } = null!;
    [Inject] IDialogService DialogService { get; set; } = null!;

    [Parameter] public Guid Id { get; set; }

    private OrderDetailDto? _order;
    private bool _loading = true;
    private OrderStatus _newStatus;
    private string? _adminNotes;
    private bool _updatingStatus, _savingNotes, _refunding;

    protected override async Task OnInitializedAsync()
    {
        _order = await AdminOrderService.GetOrderAsync(Id);
        if (_order is not null)
        {
            _newStatus = _order.Status;
            _adminNotes = _order.AdminNotes;
        }
        _loading = false;
    }

    private async Task UpdateStatusAsync()
    {
        _updatingStatus = true;
        try
        {
            var response = await AdminOrderService.UpdateStatusAsync(Id, _newStatus);
            if (response.IsSuccessStatusCode)
            {
                _order = _order! with { Status = _newStatus };
                Snackbar.Add("Status updated — customer notified by email", Severity.Success);
            }
            else
            {
                Snackbar.Add("Failed to update status", Severity.Error);
            }
        }
        finally { _updatingStatus = false; }
    }

    private async Task SaveNotesAsync()
    {
        _savingNotes = true;
        try
        {
            var response = await AdminOrderService.UpdateNotesAsync(Id, _adminNotes);
            if (response.IsSuccessStatusCode)
                Snackbar.Add("Notes saved", Severity.Success);
            else
                Snackbar.Add("Failed to save notes", Severity.Error);
        }
        finally { _savingNotes = false; }
    }

    private async Task RefundOrderAsync()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Confirm Refund",
            $"Issue a full refund of £{_order!.Total:F2} for order {_order.OrderNumber}? This cannot be undone.",
            yesText: "Yes, Refund",
            cancelText: "Cancel");
        if (confirmed is not true) return;

        _refunding = true;
        try
        {
            var response = await AdminOrderService.RefundAsync(Id);
            if (response.IsSuccessStatusCode)
            {
                _order = _order! with { Status = OrderStatus.Refunded };
                _newStatus = OrderStatus.Refunded;
                Snackbar.Add("Refund issued successfully", Severity.Success);
            }
            else
            {
                Snackbar.Add("Failed to issue refund. Check Stripe dashboard.", Severity.Error);
            }
        }
        finally { _refunding = false; }
    }

    private static Color StatusColor(OrderStatus status) => status switch
    {
        OrderStatus.Confirmed or OrderStatus.Processing or OrderStatus.ReadyForCollection or OrderStatus.Dispatched => Color.Success,
        OrderStatus.Pending => Color.Warning,
        OrderStatus.Cancelled or OrderStatus.Refunded => Color.Error,
        _ => Color.Default
    };
}
