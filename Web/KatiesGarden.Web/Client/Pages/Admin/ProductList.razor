@page "/admin/products"
@layout AdminLayout
@using KatiesGarden.Models.Shop

<PageTitle>Products — Admin</PageTitle>

<div class="d-flex align-items-center mb-6">
    <MudText Typo="Typo.h4" Class="font-weight-bold flex-grow-1">Products</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               Href="/admin/products/new">
        New Product
    </MudButton>
</div>

@if (_loading)
{
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="300px" />
}
else
{
    <MudTable Items="_products" Dense="false" Hover="true" Striped="true" Filter="FilterFunc">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="Search products…" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Price</MudTh>
            <MudTh>Stock</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>£@context.Price.ToString("F2")</MudTd>
            <MudTd>@(context.StockQuantity?.ToString() ?? "Not tracked")</MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.IsAvailable ? Color.Success : Color.Error)" Size="Size.Small">
                    @(context.IsAvailable ? "Available" : "Unavailable")
                </MudChip>
            </MudTd>
            <MudTd>
                <MudButton Size="Size.Small" Href="@($"/admin/products/{context.Id}/edit")">Edit</MudButton>
                <MudButton Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Id, context.Name))">Delete</MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No products found.</MudText>
        </NoRecordsContent>
    </MudTable>
}

@code {
    [Inject] AdminProductService AdminProductService { get; set; } = null!;
    [Inject] ISnackbar Snackbar { get; set; } = null!;
    [Inject] IDialogService DialogService { get; set; } = null!;

    private List<ProductSummaryDto> _products = [];
    private string _search = string.Empty;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _products = await AdminProductService.GetProductsAsync() ?? [];
        _loading = false;
    }

    private bool FilterFunc(ProductSummaryDto p) =>
        string.IsNullOrWhiteSpace(_search) ||
        p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase);

    private async Task DeleteAsync(Guid id, string name)
    {
        var result = await DialogService.ShowMessageBox(
            "Delete Product",
            $"Are you sure you want to delete \"{name}\"? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");

        if (result != true) return;

        var response = await AdminProductService.DeleteProductAsync(id);
        if (response.IsSuccessStatusCode)
        {
            _products.RemoveAll(p => p.Id == id);
            Snackbar.Add("Product deleted", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to delete product", Severity.Error);
        }
    }
}
