@page "/cart"
@implements IDisposable

<PageTitle>Basket — Katie's Garden</PageTitle>

<!-- Progress breadcrumb -->
<div class="bg-base-200 border-b border-base-300">
    <div class="max-w-4xl mx-auto px-4 py-3">
        <ol class="flex items-center gap-2 text-sm">
            <li class="flex items-center gap-1 text-primary font-medium">
                <span class="w-5 h-5 rounded-full bg-primary text-primary-content flex items-center justify-center text-xs font-medium">1</span>
                Basket
            </li>
            <li class="text-base-content/30">›</li>
            <li class="flex items-center gap-1 text-base-content/40">
                <span class="w-5 h-5 rounded-full bg-base-300 text-base-content/40 flex items-center justify-center text-xs font-medium">2</span>
                Your Details
            </li>
            <li class="text-base-content/30">›</li>
            <li class="flex items-center gap-1 text-base-content/40">
                <span class="w-5 h-5 rounded-full bg-base-300 text-base-content/40 flex items-center justify-center text-xs font-medium">3</span>
                Payment
            </li>
        </ol>
    </div>
</div>

<div class="max-w-2xl mx-auto px-4 py-8">
    <h1 class="font-serif text-3xl font-semibold text-base-content mb-8">Your Basket</h1>

    @if (_items.Count == 0)
    {
        <div class="text-center py-16">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-base-content/20 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 3h2l.4 2M7 13h10l4-10H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <p class="text-base-content/60 mb-6">Your basket is empty.</p>
            <a href="/shop" class="btn btn-primary">Browse our shop</a>
        </div>
    }
    else
    {
        <!-- Line items -->
        <ul class="divide-y divide-base-300 mb-6">
            @foreach (var item in _items)
            {
                <li @key="item.ProductId" class="flex items-start gap-3 py-4">
                    @if (item.ImageUrl is not null)
                    {
                        <img src="@item.ImageUrl" alt="@item.ProductName"
                             class="w-16 h-16 rounded-lg object-cover shrink-0" />
                    }
                    else
                    {
                        <div class="w-16 h-16 rounded-lg bg-base-200 shrink-0 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-base-content/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                        </div>
                    }
                    <div class="flex-1 min-w-0">
                        <p class="font-medium text-base-content">@item.ProductName</p>
                        <p class="text-sm text-primary mt-0.5">£@item.UnitPrice.ToString("F2") each</p>
                        <!-- Line total shown on mobile below name -->
                        <p class="text-sm font-medium text-base-content mt-1 sm:hidden">£@item.LineTotal.ToString("F2")</p>
                    </div>
                    <!-- Qty control -->
                    <div class="flex items-center join shrink-0">
                        <button type="button" class="btn btn-outline join-item btn-xs px-2"
                                @onclick="() => UpdateQuantityAsync(item.ProductId, item.Quantity - 1)"
                                disabled="@(item.Quantity <= 1)">−</button>
                        <span class="join-item flex items-center justify-center px-3 text-sm font-medium border border-base-300 bg-base-100 h-8 min-w-[2.5rem]">@item.Quantity</span>
                        <button type="button" class="btn btn-outline join-item btn-xs px-2"
                                @onclick="() => UpdateQuantityAsync(item.ProductId, item.Quantity + 1)">+</button>
                    </div>
                    <!-- Line total (desktop) -->
                    <span class="hidden sm:block text-sm font-medium text-base-content min-w-[4rem] text-right shrink-0">£@item.LineTotal.ToString("F2")</span>
                    <!-- Remove -->
                    <button type="button" class="btn btn-ghost btn-xs text-error shrink-0 p-1"
                            @onclick="() => RemoveAsync(item.ProductId)"
                            aria-label="Remove @item.ProductName">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </li>
            }
        </ul>

        <!-- Delivery selection -->
        <div class="card bg-base-100 border border-base-300 shadow-sm mb-5">
            <div class="card-body gap-3">
                <fieldset>
                <legend class="card-title text-base">Delivery Method</legend>

                <label class="flex items-start gap-3 p-3 rounded-xl cursor-pointer border-2 transition-colors @(_deliveryType == DeliveryType.Collection ? "border-primary bg-primary/5" : "border-base-300 hover:border-base-content/20")">
                    <input type="radio" name="delivery" value="Collection" checked="@(_deliveryType == DeliveryType.Collection)"
                           @onchange="SelectCollection" class="radio radio-primary mt-0.5 shrink-0" />
                    <div>
                        <p class="font-medium">Click &amp; Collect — Free</p>
                        @if (_deliverySettings is not null)
                        {
                            <p class="text-sm text-base-content/60">@_deliverySettings.CollectionAddress</p>
                        }
                    </div>
                </label>

                @if (_allCanDeliver)
                {
                    <label class="flex items-start gap-3 p-3 rounded-xl cursor-pointer border-2 transition-colors @(_deliveryType == DeliveryType.LocalDelivery ? "border-primary bg-primary/5" : "border-base-300 hover:border-base-content/20")">
                        <input type="radio" name="delivery" value="LocalDelivery" checked="@(_deliveryType == DeliveryType.LocalDelivery)"
                               @onchange="SelectLocalDelivery" class="radio radio-primary mt-0.5 shrink-0" />
                        <div>
                            <p class="font-medium">Local Delivery — @DeliveryFeeLabel</p>
                            @if (_deliverySettings is not null)
                            {
                                <p class="text-sm text-base-content/60">@_deliverySettings.DeliveryAreaDescription</p>
                            }
                        </div>
                    </label>
                }
                else
                {
                    <div role="note" class="text-sm text-warning flex items-center gap-2 px-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        One or more items are collection-only.
                    </div>
                }
                </fieldset>
            </div>
        </div>

        <!-- Order totals -->
        <div class="card bg-base-200 border border-base-300 shadow-sm mb-6">
            <div class="card-body gap-3">
                <div class="flex justify-between text-sm text-base-content/70">
                    <span>Subtotal</span>
                    <span>£@_subtotal.ToString("F2")</span>
                </div>
                <div class="flex justify-between text-sm text-base-content/70">
                    <span>Delivery</span>
                    <span>@(_deliveryFee == 0 ? "Free" : $"£{_deliveryFee:F2}")</span>
                </div>
                <div class="border-t border-base-300 pt-3 flex justify-between font-semibold text-base-content">
                    <span>Total</span>
                    <span class="text-primary text-lg">£@((_subtotal + _deliveryFee).ToString("F2"))</span>
                </div>
            </div>
        </div>

        <button type="button" class="btn btn-primary btn-lg w-full gap-2"
                @onclick="ProceedToCheckoutAsync" disabled="@_checkingOut">
            @if (_checkingOut)
            {
                <span class="loading loading-spinner loading-sm"></span>
                <span>Redirecting…</span>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                <span>Proceed to Checkout</span>
            }
        </button>

        <p class="text-xs text-center text-base-content/40 mt-3">Secure payment via Stripe. Your details are never stored on our servers.</p>
    }
</div>
