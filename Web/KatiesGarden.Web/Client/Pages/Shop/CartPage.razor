@page "/cart"
@using KatiesGarden.Models.Shop
@using KatiesGarden.Web.Client.Models
@implements IDisposable

<PageTitle>Basket — Katie's Garden</PageTitle>

<div class="max-w-3xl mx-auto px-6 py-12">

    <h1 class="font-serif text-4xl font-bold text-base-content mb-8">Your Basket</h1>

    @if (_items.Count == 0)
    {
        <div class="text-center py-20">
            <i class="fas fa-basket-shopping text-5xl text-base-content/20 mb-4" aria-hidden="true"></i>
            <p class="text-base-content/65 mb-4">Your basket is empty.</p>
            <a href="/shop" class="btn btn-primary">Browse Our Shop</a>
        </div>
    }
    else
    {
        <!-- Line items -->
        <div class="flex flex-col divide-y divide-base-300 mb-8">
            @foreach (var item in _items)
            {
                <div @key="item.ProductId" class="flex items-center gap-3 py-4">
                    @if (item.ImageUrl is not null)
                    {
                        <img src="@item.ImageUrl" alt="@item.ProductName"
                             class="w-16 h-16 object-cover rounded-lg flex-shrink-0" loading="lazy" />
                    }
                    else
                    {
                        <div class="w-16 h-16 bg-base-200 rounded-lg flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-seedling text-primary/30" aria-hidden="true"></i>
                        </div>
                    }

                    <div class="flex-1 min-w-0">
                        <p class="font-semibold text-base-content truncate">@item.ProductName</p>
                        <p class="text-primary text-sm">£@item.UnitPrice.ToString("F2") each</p>
                        <!-- Line total shown here on mobile (the standalone column is hidden < sm) -->
                        <p class="text-base-content font-semibold text-sm sm:hidden mt-0.5">
                            £@item.LineTotal.ToString("F2")
                        </p>
                    </div>

                    <input type="number"
                           class="input input-bordered input-sm w-16 text-center flex-shrink-0"
                           value="@item.Quantity"
                           min="0" max="99"
                           @onchange="e => UpdateQuantityAsync(item.ProductId, int.TryParse(e.Value?.ToString(), out var q) ? q : item.Quantity)"
                           aria-label="@($"Quantity for {item.ProductName}")" />

                    <p class="hidden sm:block text-base-content font-semibold w-16 text-right flex-shrink-0">
                        £@item.LineTotal.ToString("F2")
                    </p>

                    <button class="btn btn-ghost btn-sm btn-square text-error hover:bg-error/10 flex-shrink-0"
                            @onclick="() => RemoveAsync(item.ProductId)"
                            aria-label="@($"Remove {item.ProductName} from basket")">
                        <i class="fas fa-trash text-sm" aria-hidden="true"></i>
                    </button>
                </div>
            }
        </div>

        <!-- Delivery method -->
        <div class="card bg-base-200 rounded-2xl mb-6">
            <div class="card-body p-5">
                <h2 class="font-semibold text-base-content mb-3">Delivery Method</h2>

                <label class="flex items-start gap-3 p-3 rounded-xl cursor-pointer hover:bg-base-300 transition-colors @(_deliveryType == "Collection" ? "bg-base-300" : "")">
                    <input type="radio"
                           class="radio radio-primary mt-0.5"
                           name="delivery"
                           checked="@(_deliveryType == "Collection")"
                           @onchange="SelectCollection" />
                    <div>
                        <p class="font-medium text-base-content">Click &amp; Collect — Free</p>
                        @if (_deliverySettings is not null)
                        {
                            <p class="text-sm text-base-content/60 mt-0.5">@_deliverySettings.CollectionAddress</p>
                        }
                    </div>
                </label>

                @if (_allCanDeliver)
                {
                    <label class="flex items-start gap-3 p-3 rounded-xl cursor-pointer hover:bg-base-300 transition-colors @(_deliveryType == "LocalDelivery" ? "bg-base-300" : "")">
                        <input type="radio"
                               class="radio radio-primary mt-0.5"
                               name="delivery"
                               checked="@(_deliveryType == "LocalDelivery")"
                               @onchange="SelectLocalDelivery" />
                        <div>
                            <p class="font-medium text-base-content">Local Delivery — @DeliveryFeeLabel</p>
                            @if (_deliverySettings is not null)
                            {
                                <p class="text-sm text-base-content/60 mt-0.5">@_deliverySettings.DeliveryAreaDescription</p>
                            }
                        </div>
                    </label>
                }
                else
                {
                    <div class="alert alert-warning text-sm mt-2">
                        <i class="fas fa-info-circle flex-shrink-0" aria-hidden="true"></i>
                        <span>One or more items in your basket are collection-only.</span>
                    </div>
                }
            </div>
        </div>

        <!-- Order summary -->
        <div class="card bg-base-200 rounded-2xl mb-6">
            <div class="card-body p-5">
                <div class="flex justify-between text-base-content/70 mb-2 text-sm">
                    <span>Subtotal</span>
                    <span>£@_subtotal.ToString("F2")</span>
                </div>
                <div class="flex justify-between text-base-content/70 mb-3 text-sm">
                    <span>Delivery</span>
                    <span>£@_deliveryFee.ToString("F2")</span>
                </div>
                <div class="divider my-0"></div>
                <div class="flex justify-between mt-3 font-bold text-lg">
                    <span class="text-base-content">Total</span>
                    <span class="text-primary">£@(_subtotal + _deliveryFee).ToString("F2")</span>
                </div>
            </div>
        </div>

        <button class="btn btn-primary btn-lg w-full"
                @onclick="ProceedToCheckoutAsync"
                disabled="@_checkingOut">
            @if (_checkingOut)
            {
                <span class="loading loading-spinner loading-sm mr-2"></span>
                <span>Redirecting to payment…</span>
            }
            else
            {
                <i class="fas fa-lock mr-2 text-sm" aria-hidden="true"></i>
                <span>Proceed to Checkout</span>
            }
        </button>
    }
</div>
