@page "/checkout"
@using KatiesGarden.Models.Shop
@using KatiesGarden.Web.Client.Models

<PageTitle>Checkout — Katie's Garden</PageTitle>

<div class="max-w-lg mx-auto px-6 py-12">

    <!-- Progress indicator -->
    <div class="flex items-center gap-2 mb-8 text-sm">
        <span class="text-base-content/40">Basket</span>
        <i class="fas fa-chevron-right text-xs text-base-content/30" aria-hidden="true"></i>
        <span class="font-semibold text-primary">Your Details</span>
        <i class="fas fa-chevron-right text-xs text-base-content/30" aria-hidden="true"></i>
        <span class="text-base-content/40">Payment</span>
    </div>

    <h1 class="font-serif text-3xl font-bold text-base-content mb-6">Your Details</h1>

    <form @onsubmit="SubmitAsync" @onsubmit:preventDefault="true" novalidate class="flex flex-col gap-4">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="form-control">
                <label class="label pb-1" for="first-name">
                    <span class="label-text font-medium">First Name <span class="text-error">*</span></span>
                </label>
                <input id="first-name" type="text"
                       class="input input-bordered @(HasError("FirstName") ? "input-error" : "")"
                       @bind="_request.FirstName"
                       autocomplete="given-name"
                       placeholder="Katie" />
                @if (HasError("FirstName"))
                {
                    <label class="label pt-1"><span class="label-text-alt text-error">@GetError("FirstName")</span></label>
                }
            </div>
            <div class="form-control">
                <label class="label pb-1" for="last-name">
                    <span class="label-text font-medium">Last Name <span class="text-error">*</span></span>
                </label>
                <input id="last-name" type="text"
                       class="input input-bordered @(HasError("LastName") ? "input-error" : "")"
                       @bind="_request.LastName"
                       autocomplete="family-name"
                       placeholder="Porter" />
                @if (HasError("LastName"))
                {
                    <label class="label pt-1"><span class="label-text-alt text-error">@GetError("LastName")</span></label>
                }
            </div>
        </div>

        <div class="form-control">
            <label class="label pb-1" for="email">
                <span class="label-text font-medium">Email Address <span class="text-error">*</span></span>
            </label>
            <input id="email" type="email"
                   class="input input-bordered @(HasError("Email") ? "input-error" : "")"
                   @bind="_request.Email"
                   autocomplete="email"
                   placeholder="katie@example.com" />
            @if (HasError("Email"))
            {
                <label class="label pt-1"><span class="label-text-alt text-error">@GetError("Email")</span></label>
            }
        </div>

        <div class="form-control">
            <label class="label pb-1" for="phone">
                <span class="label-text font-medium">Phone Number <span class="text-error">*</span></span>
            </label>
            <input id="phone" type="tel"
                   class="input input-bordered @(HasError("Phone") ? "input-error" : "")"
                   @bind="_request.Phone"
                   autocomplete="tel"
                   placeholder="07800 000000" />
            @if (HasError("Phone"))
            {
                <label class="label pt-1"><span class="label-text-alt text-error">@GetError("Phone")</span></label>
            }
        </div>

        @if (_deliveryType == "LocalDelivery")
        {
            <div class="form-control">
                <label class="label pb-1" for="address">
                    <span class="label-text font-medium">Delivery Address <span class="text-error">*</span></span>
                </label>
                <textarea id="address"
                          class="textarea textarea-bordered @(HasError("DeliveryAddress") ? "textarea-error" : "")"
                          rows="2"
                          @bind="_request.DeliveryAddress"
                          autocomplete="street-address"
                          placeholder="1 Garden Lane, Milverton"></textarea>
                @if (HasError("DeliveryAddress"))
                {
                    <label class="label pt-1"><span class="label-text-alt text-error">@GetError("DeliveryAddress")</span></label>
                }
            </div>
            <div class="form-control">
                <label class="label pb-1" for="postcode">
                    <span class="label-text font-medium">Postcode <span class="text-error">*</span></span>
                </label>
                <input id="postcode" type="text"
                       class="input input-bordered @(HasError("DeliveryPostcode") ? "input-error" : "")"
                       @bind="_request.DeliveryPostcode"
                       autocomplete="postal-code"
                       placeholder="TA4 1AB" />
                @if (HasError("DeliveryPostcode"))
                {
                    <label class="label pt-1"><span class="label-text-alt text-error">@GetError("DeliveryPostcode")</span></label>
                }
            </div>
        }

        <div class="form-control">
            <label class="label pb-1" for="notes">
                <span class="label-text font-medium">Order Notes <span class="text-base-content/40 font-normal">(optional)</span></span>
            </label>
            <textarea id="notes"
                      class="textarea textarea-bordered"
                      rows="3"
                      @bind="_request.Notes"
                      placeholder="Any special instructions…"></textarea>
        </div>

        @if (_error is not null)
        {
            <div class="alert alert-error" role="alert">
                <i class="fas fa-exclamation-circle flex-shrink-0" aria-hidden="true"></i>
                <span>@_error</span>
            </div>
        }

        <button type="submit" class="btn btn-primary btn-lg w-full mt-2" disabled="@_submitting">
            @if (_submitting)
            {
                <span class="loading loading-spinner loading-sm mr-2"></span>
                <span>Preparing payment…</span>
            }
            else
            {
                <i class="fas fa-lock mr-2 text-sm" aria-hidden="true"></i>
                <span>Continue to Payment</span>
            }
        </button>
    </form>
</div>
