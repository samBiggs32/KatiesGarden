@page "/order/success"
@using KatiesGarden.Models.Shop
@inject ShopService ShopService

<PageTitle>Order Confirmed — Katie's Garden</PageTitle>

<div class="max-w-lg mx-auto px-6 py-20 text-center">
    <div class="w-20 h-20 rounded-full bg-success/15 flex items-center justify-center mx-auto mb-6">
        <i class="fas fa-check text-success text-4xl" aria-hidden="true"></i>
    </div>

    <h1 class="font-serif text-4xl font-bold text-base-content mb-4">
        Thank you for your order!
    </h1>

    @if (_order is not null)
    {
        <div class="bg-base-200 rounded-2xl p-5 mb-6 text-left">
            <div class="flex justify-between items-center mb-3">
                <span class="text-sm text-base-content/60 uppercase tracking-wide font-medium">Order number</span>
                <span class="font-mono font-semibold text-base-content">@_order.OrderNumber</span>
            </div>
            @if (_order.Lines.Count > 0)
            {
                <ul class="divide-y divide-base-300 mb-3">
                    @foreach (var line in _order.Lines)
                    {
                        <li class="py-2 flex justify-between text-sm">
                            <span class="text-base-content/80">@line.ProductName × @line.Quantity</span>
                            <span class="font-medium">£@line.LineTotal.ToString("F2")</span>
                        </li>
                    }
                </ul>
            }
            <div class="flex justify-between text-sm text-base-content/70 border-t border-base-300 pt-2">
                <span>Delivery</span>
                <span>@(_order.DeliveryFee > 0 ? $"£{_order.DeliveryFee:F2}" : "Free (Click & Collect)")</span>
            </div>
            <div class="flex justify-between font-semibold mt-1">
                <span>Total</span>
                <span class="text-primary">£@_order.Total.ToString("F2")</span>
            </div>
        </div>
    }

    <p class="text-base-content/65 text-lg mb-8 leading-relaxed max-w-sm mx-auto">
        A confirmation email is on its way.
        Katie will be in touch to arrange @(_order?.DeliveryType == DeliveryType.LocalDelivery ? "delivery" : "collection").
    </p>

    <div class="flex gap-3 justify-center flex-wrap">
        <a href="/shop" class="btn btn-primary">
            Continue Shopping
        </a>
        <a href="/" class="btn btn-ghost">
            Return Home
        </a>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "session_id")] public string? SessionId { get; set; }

    private OrderLookupDto? _order;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(SessionId))
        {
            try { _order = await ShopService.GetOrderLookupAsync(SessionId); }
            catch { /* non-critical — page still works without order details */ }
        }
    }
}
