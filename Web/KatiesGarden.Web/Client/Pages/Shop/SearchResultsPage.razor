@page "/shop/search"
@using KatiesGarden.Models.Shop
@inject ShopService ShopService
@inject NavigationManager Navigation

<PageTitle>@(_query.Length > 0 ? $"Search: {_query}" : "Search") — Katie's Garden</PageTitle>

<div class="max-w-5xl mx-auto px-4 py-8">

    <!-- Search bar -->
    <div class="mb-8">
        <h1 class="font-serif text-3xl font-semibold text-base-content mb-4">Search the shop</h1>
        <form @onsubmit="Search" @onsubmit:preventDefault>
            <div class="flex gap-2 max-w-xl">
                <input type="search" @bind="_inputQuery" @bind:event="oninput"
                       placeholder="What are you looking for?"
                       class="input input-bordered flex-1"
                       aria-label="Search query" />
                <button type="submit" class="btn btn-primary gap-2">
                    <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
                    Search
                </button>
            </div>
        </form>
    </div>

    @if (_loading)
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @for (int i = 0; i < 6; i++)
            {
                <div class="card bg-base-100 border border-base-300 shadow-sm">
                    <div class="skeleton aspect-square rounded-t-2xl"></div>
                    <div class="card-body gap-2">
                        <div class="skeleton h-5 w-3/4"></div>
                        <div class="skeleton h-4 w-1/3"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (_query.Length > 0)
    {
        <!-- Toolbar: result count + sort -->
        <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
            <p class="text-sm text-base-content/60">
                @if (_results.Count == 0)
                {
                    <span>No products found for "<strong>@_query</strong>".</span>
                }
                else
                {
                    <span>@_results.Count result@(_results.Count == 1 ? "" : "s") for "<strong>@_query</strong>"</span>
                }
            </p>

            @if (_results.Count > 1)
            {
                <select class="select select-bordered select-sm" @onchange="OnSortChanged" value="@_sort">
                    <option value="featured">Featured</option>
                    <option value="price_asc">Price: Low to High</option>
                    <option value="price_desc">Price: High to Low</option>
                    <option value="name">Name A–Z</option>
                </select>
            }
        </div>

        @if (_results.Count == 0)
        {
            <div class="text-center py-16">
                <i class="fas fa-seedling text-5xl text-base-content/20 mb-4" aria-hidden="true"></i>
                <p class="text-base-content/50 mb-4">Try a different search term, or browse our collections.</p>
                <a href="/shop" class="btn btn-primary">Browse all collections</a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var p in _results)
                {
                    <a @key="p.Id" href="/shop/product/@p.Slug"
                       class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all group">
                        <figure class="aspect-square overflow-hidden rounded-t-2xl bg-base-200">
                            @if (p.ImageUrl is not null)
                            {
                                <img src="@p.ImageUrl" alt="@p.Name"
                                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                     loading="lazy" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center">
                                    <i class="fas fa-seedling text-4xl text-base-content/20" aria-hidden="true"></i>
                                </div>
                            }
                        </figure>
                        <div class="card-body p-4 gap-1">
                            @if (p.CollectionTitle is not null)
                            {
                                <p class="text-xs text-base-content/50 uppercase tracking-wide">@p.CollectionTitle</p>
                            }
                            <h2 class="font-serif font-semibold text-base-content leading-tight">@p.Name</h2>
                            <p class="text-primary font-semibold">£@p.Price.ToString("F2")</p>
                            <div class="flex gap-1 flex-wrap mt-1">
                                <StockBadge IsAvailable="@p.IsAvailable" StockQuantity="@p.StockQuantity" />
                                @if (!p.CanLocalDeliver)
                                {
                                    <span class="badge badge-outline badge-sm">Collection only</span>
                                }
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "q")] public string? Q { get; set; }

    private string _query = string.Empty;
    private string _inputQuery = string.Empty;
    private string _sort = "featured";
    private bool _loading;
    private List<ProductSearchResultDto> _results = [];

    protected override async Task OnParametersSetAsync()
    {
        var newQuery = Q?.Trim() ?? string.Empty;
        if (newQuery == _query && !_loading) return;

        _query = newQuery;
        _inputQuery = _query;

        if (_query.Length == 0) { _results = []; return; }

        _loading = true;
        StateHasChanged();
        try { _results = await ShopService.SearchAsync(_query, _sort); }
        finally { _loading = false; }
    }

    private void Search()
    {
        var q = _inputQuery.Trim();
        if (string.IsNullOrWhiteSpace(q)) return;
        // Navigating updates the `q` query parameter, which triggers OnParametersSetAsync to
        // run the search. Fetching here as well would issue the same query a second time.
        Navigation.NavigateTo($"/shop/search?q={Uri.EscapeDataString(q)}");
    }

    private async Task OnSortChanged(ChangeEventArgs e)
    {
        _sort = e.Value?.ToString() ?? "featured";
        if (_query.Length == 0) return;
        _loading = true;
        StateHasChanged();
        try { _results = await ShopService.SearchAsync(_query, _sort); }
        finally { _loading = false; StateHasChanged(); }
    }
}
