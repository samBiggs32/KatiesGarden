@page "/shop/{Slug}"
@using KatiesGarden.Models.Shop
@using KatiesGarden.Web.Client.Models

<PageTitle>@(_collection?.Title ?? "Collection") — Katie's Garden</PageTitle>

<!-- Toast notification -->
@if (_toast is not null)
{
    <div class="toast toast-top toast-end z-50" role="status" aria-live="polite">
        <div class="alert alert-success shadow-lg">
            <i class="fas fa-check-circle" aria-hidden="true"></i>
            <span>@_toast</span>
        </div>
    </div>
}

<div class="max-w-7xl mx-auto px-6 py-12">

    @if (_loading)
    {
        <div class="mb-8">
            <div class="bg-base-300 h-8 rounded w-64 mb-3 animate-pulse"></div>
            <div class="bg-base-300 h-5 rounded w-96 animate-pulse"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @for (int i = 0; i < 6; i++)
            {
                <div class="card bg-base-100 shadow-md animate-pulse">
                    <div class="bg-base-300 aspect-square rounded-t-2xl"></div>
                    <div class="card-body gap-2">
                        <div class="bg-base-300 h-5 rounded w-3/4"></div>
                        <div class="bg-base-300 h-4 rounded w-1/3"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (_collection is null)
    {
        <div class="text-center py-20">
            <i class="fas fa-exclamation-circle text-5xl text-warning/50 mb-4" aria-hidden="true"></i>
            <p class="text-base-content/65">Collection not found.</p>
            <a href="/shop" class="btn btn-outline btn-primary mt-4">Back to Shop</a>
        </div>
    }
    else
    {
        <!-- Breadcrumb -->
        <nav class="text-sm text-base-content/50 mb-6" aria-label="Breadcrumb">
            <a href="/shop" class="hover:text-primary transition-colors">Shop</a>
            <span class="mx-2" aria-hidden="true">/</span>
            <span class="text-base-content/80">@_collection.Title</span>
        </nav>

        <div class="mb-8">
            <h1 class="font-serif text-4xl font-bold text-base-content mb-2">@_collection.Title</h1>
            @if (!string.IsNullOrEmpty(_collection.Description))
            {
                <p class="text-base-content/65 text-lg max-w-2xl">@_collection.Description</p>
            }
        </div>

        @if (_collection.Products.Count == 0)
        {
            <div class="text-center py-20">
                <i class="fas fa-seedling text-5xl text-primary/20 mb-4" aria-hidden="true"></i>
                <p class="text-base-content/65">No products in this collection yet.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var product in _collection.Products)
                {
                    <div @key="product.Id" class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow rounded-2xl overflow-hidden group">
                        <a href="/shop/product/@product.Slug" class="block aspect-square overflow-hidden">
                            @if (product.CoverImageUrl is not null)
                            {
                                <img src="@product.CoverImageUrl"
                                     alt="@product.Name"
                                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                     loading="lazy" />
                            }
                            else
                            {
                                <div class="w-full h-full bg-base-200 flex items-center justify-center">
                                    <i class="fas fa-seedling text-4xl text-primary/20" aria-hidden="true"></i>
                                </div>
                            }
                        </a>

                        <div class="card-body p-4">
                            <a href="/shop/product/@product.Slug"
                               class="font-serif text-lg font-semibold text-base-content hover:text-primary transition-colors leading-tight">
                                @product.Name
                            </a>
                            <p class="text-primary font-bold text-lg">£@product.Price.ToString("F2")</p>

                            @if (!string.IsNullOrEmpty(product.Description))
                            {
                                <p class="text-base-content/60 text-sm line-clamp-2">@product.Description</p>
                            }

                            <div class="flex items-center gap-2 mt-1 flex-wrap">
                                @if (!product.IsAvailable)
                                {
                                    <span class="badge badge-error badge-sm">Sold out</span>
                                }
                                else if (product.StockQuantity is > 0 and <= 3)
                                {
                                    <span class="badge badge-warning badge-sm">Only @product.StockQuantity left</span>
                                }
                                else
                                {
                                    <span class="badge badge-success badge-sm">In stock</span>
                                }
                            </div>

                            <div class="card-actions mt-3 gap-2">
                                <a href="/shop/product/@product.Slug" class="btn btn-ghost btn-sm">View</a>
                                <button class="btn btn-primary btn-sm flex-1"
                                        disabled="@(!product.IsAvailable)"
                                        @onclick="() => AddToCartAsync(product)">
                                    <i class="fas fa-basket-shopping text-xs" aria-hidden="true"></i>
                                    Add to Basket
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>
