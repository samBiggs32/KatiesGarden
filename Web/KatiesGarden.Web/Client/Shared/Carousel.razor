@using KatiesGarden.Web.Client.Models

<div class="m-1 background-colour-primary">
    <div class="image-container">
        <div class="crop">
            <MudCarousel Class="carousel-size w-100" ShowArrows="@arrows" ShowBullets="@showBullets" AutoCycle="@autocycle" TData="object"
                         aria-label="Garden photo slideshow" role="region">
                <ChildContent>
                    @for (int i = 0; i < Images.Slides.Count; i++)
                    {
                        var slide = Images.Slides[i];
                        var isFirst = i == 0;
                        <MudCarouselItem Transition="transition" Color="@transitionColour">
                            <div class="d-flex">
                                <picture class="d-block w-100">
                                    <source type="image/webp" srcset="@slide.WebpSrc" />
                                    <img class="d-block w-100"
                                         loading="@(isFirst ? "eager" : "lazy")"
                                         style="max-height: 100%; max-width: 100%; object-fit: cover;"
                                         src="@slide.Src"
                                         srcset="@slide.SrcSet"
                                         sizes="100vw"
                                         alt="@slide.Alt" />
                                </picture>
                            </div>
                        </MudCarouselItem>
                    }
                </ChildContent>
            </MudCarousel>
        </div>
    </div>
</div>

@code {
    private bool arrows = true;
    private bool showBullets = false;
    private bool autocycle = true;
    private Transition transition = Transition.Fade;
    private Color transitionColour = Color.Transparent;
}
