@inject CartService CartService
@inject AuthService AuthService
@inject NavigationManager Navigation
@implements IAsyncDisposable
@using KatiesGarden.Models.Auth

<div class="sticky top-0 z-50 bg-base-100 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">

        <!-- Contact strip — desktop only -->
        <div class="hidden md:flex justify-end items-center gap-6 py-1.5 text-sm border-b border-base-300 text-base-content/60">
            <a href="tel:+447804784522"
               class="flex items-center gap-1.5 hover:text-primary transition-colors">
                <i class="fas fa-phone text-xs" aria-hidden="true"></i>
                <span>07804 784522</span>
            </a>
            <a href="mailto:sales@katiesgarden.uk"
               class="flex items-center gap-1.5 hover:text-primary transition-colors">
                <i class="fas fa-envelope text-xs" aria-hidden="true"></i>
                <span>sales@katiesgarden.uk</span>
            </a>
        </div>

        <!-- Main bar -->
        <div class="flex items-center justify-between py-3 gap-4">

            <!-- Logo -->
            <a href="/" aria-label="Katie's Garden — home">
                <img src="Images/Katies-Garden-(long) 2.gif"
                     alt="Katie's Garden"
                     class="h-12 md:h-14 w-auto" />
            </a>

            <!-- Desktop nav links -->
            <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
                <NavLink href="" Match="NavLinkMatch.All"
                         class="px-3 py-1.5 rounded-md text-sm font-medium text-base-content hover:text-primary hover:bg-base-200 transition-colors"
                         ActiveClass="text-primary bg-base-200">
                    Home
                </NavLink>
                <NavLink href="gallery"
                         class="px-3 py-1.5 rounded-md text-sm font-medium text-base-content hover:text-primary hover:bg-base-200 transition-colors"
                         ActiveClass="text-primary bg-base-200">
                    Gallery
                </NavLink>
                <NavLink href="shop"
                         class="px-3 py-1.5 rounded-md text-sm font-medium text-base-content hover:text-primary hover:bg-base-200 transition-colors"
                         ActiveClass="text-primary bg-base-200">
                    Shop
                </NavLink>
                <NavLink href="contact"
                         class="px-3 py-1.5 rounded-md text-sm font-medium text-base-content hover:text-primary hover:bg-base-200 transition-colors"
                         ActiveClass="text-primary bg-base-200">
                    Contact
                </NavLink>
                @if (_isAuthenticated && !_isAdmin)
                {
                    <NavLink href="my-orders"
                             class="px-3 py-1.5 rounded-md text-sm font-medium text-base-content hover:text-primary hover:bg-base-200 transition-colors"
                             ActiveClass="text-primary bg-base-200">
                        <i class="fas fa-receipt text-xs mr-1" aria-hidden="true"></i> My Orders
                    </NavLink>
                }
                @if (_isAdmin)
                {
                    <NavLink href="admin"
                             class="px-3 py-1.5 rounded-md text-sm font-medium text-base-content hover:text-primary hover:bg-base-200 transition-colors"
                             ActiveClass="text-primary bg-base-200">
                        <i class="fas fa-lock text-xs mr-1" aria-hidden="true"></i> Admin
                    </NavLink>
                }
            </nav>

            <!-- Right: search + cart + mobile toggle -->
            <div class="flex items-center gap-1">

                <!-- Search toggle (desktop) -->
                <button class="hidden md:flex p-2 rounded-md text-base-content hover:text-primary hover:bg-base-200 transition-colors"
                        @onclick="ToggleSearch"
                        aria-label="Search products"
                        aria-expanded="@_searchOpen">
                    <i class="fas fa-magnifying-glass text-lg" aria-hidden="true"></i>
                </button>

                <!-- Cart icon -->
                <NavLink href="cart"
                         class="relative p-2 rounded-md text-base-content hover:text-primary hover:bg-base-200 transition-colors"
                         aria-label="@(_cartCount > 0 ? $"View basket — {_cartCount} item{(_cartCount == 1 ? "" : "s")}" : "View basket")">
                    <i class="fas fa-basket-shopping text-lg" aria-hidden="true"></i>
                    @if (_cartCount > 0)
                    {
                        <span class="absolute -top-0.5 -right-0.5 flex items-center justify-center w-5 h-5 rounded-full bg-primary text-primary-content text-xs font-bold leading-none"
                              aria-hidden="true">
                            @_cartCount
                        </span>
                    }
                </NavLink>

                <!-- Mobile hamburger -->
                <button class="md:hidden p-2 rounded-md text-base-content hover:text-primary hover:bg-base-200 transition-colors"
                        @onclick="ToggleNavMenu"
                        aria-label="Toggle navigation"
                        aria-expanded="@(!collapseNavMenu)"
                        aria-controls="mobile-nav">
                    @if (collapseNavMenu)
                    {
                        <i class="fas fa-bars text-lg" aria-hidden="true"></i>
                    }
                    else
                    {
                        <i class="fas fa-times text-lg" aria-hidden="true"></i>
                    }
                </button>
            </div>
        </div>

        <!-- Inline search bar (desktop) -->
        @if (_searchOpen)
        {
            <div class="hidden md:block pb-3" @onkeydown="OnSearchKeyDown">
                <div class="relative max-w-xl mx-auto">
                    <input @ref="_searchInput" type="search" @bind="_searchQuery" @bind:event="oninput"
                           placeholder="Search products…"
                           class="input input-bordered w-full pr-10"
                           aria-label="Search products" />
                    <button class="absolute right-3 top-1/2 -translate-y-1/2 text-base-content/50 hover:text-primary"
                            @onclick="ExecuteSearch" aria-label="Submit search">
                        <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
        }

        <!-- Mobile menu -->
        @if (!collapseNavMenu)
        {
            <nav id="mobile-nav" class="md:hidden pb-4 border-t border-base-300 flex flex-col gap-0.5 pt-2"
                 aria-label="Mobile navigation">

                <!-- Mobile search -->
                <div class="px-3 pb-2" @onkeydown="OnSearchKeyDown">
                    <div class="relative">
                        <input type="search" @bind="_searchQuery" @bind:event="oninput"
                               placeholder="Search products…"
                               class="input input-bordered input-sm w-full pr-9"
                               aria-label="Search products" />
                        <button class="absolute right-2.5 top-1/2 -translate-y-1/2 text-base-content/50 hover:text-primary"
                                @onclick="ExecuteSearch" aria-label="Submit search">
                            <i class="fas fa-magnifying-glass text-sm" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>

                <NavLink href="" Match="NavLinkMatch.All"
                         class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium text-base-content hover:bg-base-200 hover:text-primary transition-colors"
                         ActiveClass="bg-base-200 text-primary"
                         @onclick="CloseNavMenu">
                    <i class="fas fa-home w-4 text-center opacity-60" aria-hidden="true"></i> Home
                </NavLink>
                <NavLink href="gallery"
                         class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium text-base-content hover:bg-base-200 hover:text-primary transition-colors"
                         ActiveClass="bg-base-200 text-primary"
                         @onclick="CloseNavMenu">
                    <i class="fas fa-images w-4 text-center opacity-60" aria-hidden="true"></i> Gallery
                </NavLink>
                <NavLink href="shop"
                         class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium text-base-content hover:bg-base-200 hover:text-primary transition-colors"
                         ActiveClass="bg-base-200 text-primary"
                         @onclick="CloseNavMenu">
                    <i class="fas fa-basket-shopping w-4 text-center opacity-60" aria-hidden="true"></i>
                    Shop
                    @if (_cartCount > 0)
                    {
                        <span class="ml-1 px-1.5 py-0.5 rounded-full bg-primary text-primary-content text-xs font-bold">@_cartCount</span>
                    }
                </NavLink>
                <NavLink href="contact"
                         class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium text-base-content hover:bg-base-200 hover:text-primary transition-colors"
                         ActiveClass="bg-base-200 text-primary"
                         @onclick="CloseNavMenu">
                    <i class="fas fa-envelope w-4 text-center opacity-60" aria-hidden="true"></i> Contact
                </NavLink>
                @if (_isAuthenticated && !_isAdmin)
                {
                    <NavLink href="my-orders"
                             class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium text-base-content hover:bg-base-200 hover:text-primary transition-colors"
                             ActiveClass="bg-base-200 text-primary"
                             @onclick="CloseNavMenu">
                        <i class="fas fa-receipt w-4 text-center opacity-60" aria-hidden="true"></i> My Orders
                    </NavLink>
                }
                @if (_isAdmin)
                {
                    <NavLink href="admin"
                             class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium text-base-content hover:bg-base-200 hover:text-primary transition-colors"
                             ActiveClass="bg-base-200 text-primary"
                             @onclick="CloseNavMenu">
                        <i class="fas fa-lock w-4 text-center opacity-60" aria-hidden="true"></i> Admin
                    </NavLink>
                }

                <!-- Mobile contact info -->
                <div class="mt-3 pt-3 border-t border-base-300 flex flex-col gap-1 text-sm opacity-60">
                    <a href="tel:+447804784522" class="flex items-center gap-2 px-3 py-1.5 hover:opacity-100 transition-opacity">
                        <i class="fas fa-phone text-xs w-4 text-center" aria-hidden="true"></i> 07804 784522
                    </a>
                    <a href="mailto:sales@katiesgarden.uk" class="flex items-center gap-2 px-3 py-1.5 hover:opacity-100 transition-opacity">
                        <i class="fas fa-envelope text-xs w-4 text-center" aria-hidden="true"></i> sales@katiesgarden.uk
                    </a>
                </div>
            </nav>
        }
    </div>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool _isAdmin;
    private bool _isAuthenticated;
    private int _cartCount;
    private bool _searchOpen;
    private string _searchQuery = string.Empty;
    private ElementReference _searchInput;

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;
    private void CloseNavMenu() => collapseNavMenu = true;

    private async void ToggleSearch()
    {
        _searchOpen = !_searchOpen;
        if (_searchOpen)
        {
            await Task.Delay(50);
            try { await _searchInput.FocusAsync(); } catch { /* non-critical */ }
        }
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") ExecuteSearch();
        if (e.Key == "Escape") { _searchOpen = false; _searchQuery = string.Empty; }
    }

    private void ExecuteSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery)) return;
        _searchOpen = false;
        collapseNavMenu = true;
        Navigation.NavigateTo($"/shop/search?q={Uri.EscapeDataString(_searchQuery.Trim())}");
        _searchQuery = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = await AuthService.IsAdminAsync();
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        await CartService.GetItemsAsync();
        _cartCount = CartService.ItemCount;
        CartService.CartChanged += OnCartChanged;
    }

    private void OnCartChanged()
    {
        _cartCount = CartService.ItemCount;
        InvokeAsync(StateHasChanged);
    }

    public ValueTask DisposeAsync()
    {
        CartService.CartChanged -= OnCartChanged;
        return ValueTask.CompletedTask;
    }
}
