@inject CartService CartService
@inject AuthService AuthService
@implements IAsyncDisposable

<nav class="navbar navbar-expand-sm navbar-light background-colour-primary p-0">
    <div class="d-flex align-items-center w-100 d-sm-none">
        <button class="navbar-toggler border-0" type="button"
                @onclick="ToggleNavMenu"
                aria-label="Toggle navigation"
                aria-expanded="@(!collapseNavMenu)"
                aria-controls="main-nav-menu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="d-block d-sm-none flex-grow-1">
            <a href="">
                <img src="Images/Katies-Garden-(long) 2.gif" alt="Katie's Garden" style="width: 100%" />
            </a>
        </div>
    </div>

    <div id="main-nav-menu" class="navbar-collapse @NavMenuCssClass ml-auto">
        <div class="nav navbar-nav ml-auto w-100">
            <div class="w-100 text-center" style="font-size:1.1em">
                <span class="phone-number-text">Contact Katie on </span>
                <a href="tel:+447804784522">
                    <span class="phone-number-text"><strong>07804 784522</strong></span>
                </a>
            </div>
            <div class="w-100 text-center" style="font-size:1.1em">
                <a href="mailto:team@katiesgarden.uk"><strong>team@katiesgarden.uk</strong></a>
            </div>
        </div>
        <div class="nav navbar-nav ml-auto w-100 justify-content-center d-none d-sm-block" style="align-items: center; text-align: center;">
            <a href="">
                <img src="Images/Katies-Garden-(long) 2.gif" alt="Katie's Garden" style="max-height: 100px" />
            </a>
            <hr>
        </div>
        <div class="nav navbar-nav ml-auto w-100 justify-content-end">
            <ul class="text-center w-100">
                <li class="nav-item active pt-1 list-orientation">
                    <div class="w-100">
                        <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="CloseNavMenu">
                            <span class="oi oi-home" aria-hidden="true"></span> Home
                        </NavLink>
                    </div>
                </li>
                <li class="nav-item pt-1 list-orientation">
                    <div class="w-100">
                        <NavLink class="nav-link" href="gallery" @onclick="CloseNavMenu">
                            <span class="oi oi-image" aria-hidden="true"></span> Gallery
                        </NavLink>
                    </div>
                </li>
                <li class="nav-item pt-1 list-orientation">
                    <div class="w-100">
                        <NavLink class="nav-link" href="shop" @onclick="CloseNavMenu">
                            <span class="oi oi-basket" aria-hidden="true"></span> Shop
                            @if (_cartCount > 0)
                            {
                                <span class="badge badge-pill badge-success ml-1" style="font-size:0.7em; vertical-align:middle;" aria-label="@_cartCount items in cart">@_cartCount</span>
                            }
                        </NavLink>
                    </div>
                </li>
                <li class="nav-item pt-1 list-orientation">
                    <div class="w-100">
                        <NavLink class="nav-link" href="contact" @onclick="CloseNavMenu">
                            <span class="oi oi-chat" aria-hidden="true"></span> Contact
                        </NavLink>
                    </div>
                </li>
                @if (_isAdmin)
                {
                    <li class="nav-item pt-1 list-orientation">
                        <div class="w-100">
                            <NavLink class="nav-link" href="admin" @onclick="CloseNavMenu">
                                <span class="oi oi-lock-locked" aria-hidden="true"></span> Admin
                            </NavLink>
                        </div>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

@code {
    private bool collapseNavMenu = true;
    private bool _isAdmin;
    private int _cartCount;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    private void CloseNavMenu() => collapseNavMenu = true;

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = await AuthService.IsAdminAsync();
        // Force the cart to load from localStorage so the badge reflects any persisted items
        await CartService.GetItemsAsync();
        _cartCount = CartService.ItemCount;
        CartService.CartChanged += OnCartChanged;
    }

    private void OnCartChanged()
    {
        _cartCount = CartService.ItemCount;
        InvokeAsync(StateHasChanged);
    }

    public ValueTask DisposeAsync()
    {
        CartService.CartChanged -= OnCartChanged;
        return ValueTask.CompletedTask;
    }
}
