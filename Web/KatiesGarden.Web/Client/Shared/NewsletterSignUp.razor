@inject HttpClient Http

<section class="py-16 bg-base-100 border-t border-base-300">
    <div class="max-w-2xl mx-auto px-6 text-center">
        <i class="fas fa-seedling text-primary text-2xl mb-4" aria-hidden="true"></i>
        <h2 class="font-serif text-3xl font-bold text-base-content mb-2">Stay Up to Date</h2>
        <p class="text-base-content/65 mb-8">
            Sign up for planting tips, seasonal offers, and news from the garden.
        </p>

        @if (_submitted)
        {
            <div class="alert alert-success max-w-md mx-auto" role="status">
                <i class="fas fa-check-circle" aria-hidden="true"></i>
                <span>Thanks for signing up — we'll be in touch when there's something worth sharing.</span>
            </div>
        }
        else
        {
            <form @onsubmit="SubscribeAsync" @onsubmit:preventDefault="true" novalidate>
                <div class="flex flex-col sm:flex-row gap-2 justify-center mb-3">
                    <input type="text"
                           class="input input-bordered w-full sm:w-40"
                           placeholder="First name (optional)"
                           @bind="_firstName"
                           disabled="@_loading"
                           autocomplete="given-name" />
                    <input type="email"
                           class="input input-bordered w-full sm:flex-1 @(_emailError.Length > 0 ? "input-error" : "")"
                           placeholder="Your email address"
                           @bind="_email"
                           disabled="@_loading"
                           required
                           autocomplete="email"
                           aria-describedby="@(_emailError.Length > 0 ? "email-error" : null)" />
                    <button type="submit"
                            class="btn btn-primary @(_loading ? "loading" : "")"
                            disabled="@_loading">
                        Subscribe
                    </button>
                </div>

                @if (_emailError.Length > 0)
                {
                    <p id="email-error" class="text-error text-sm mt-1" role="alert">@_emailError</p>
                }

                <label class="flex items-start gap-2 max-w-md mx-auto text-left cursor-pointer mt-2">
                    <input type="checkbox"
                           class="checkbox checkbox-primary checkbox-sm mt-0.5 flex-shrink-0"
                           @bind="_consent"
                           aria-describedby="@(_consentError ? "consent-error" : null)" />
                    <span class="text-xs text-base-content/60 leading-relaxed">
                        I agree to receive occasional email updates from Katie's Garden.
                        You can unsubscribe at any time. We will never share your email with third parties.
                    </span>
                </label>
                @if (_consentError)
                {
                    <p id="consent-error" class="text-error text-xs mt-1" role="alert">Please tick the box to subscribe.</p>
                }
            </form>
        }
    </div>
</section>

@code {
    private static readonly SubscribeRequestValidator _validator = new();

    string _email = string.Empty;
    string _firstName = string.Empty;
    string _emailError = string.Empty;
    bool _consent;
    bool _consentError;
    bool _loading;
    bool _submitted;

    async Task SubscribeAsync()
    {
        _emailError = string.Empty;
        _consentError = false;

        var request = new SubscribeRequest(_email.Trim(), string.IsNullOrWhiteSpace(_firstName) ? null : _firstName.Trim());
        var validation = _validator.Validate(request);

        if (!validation.IsValid)
            _emailError = validation.Errors.First().ErrorMessage;

        if (!_consent)
            _consentError = true;

        if (!validation.IsValid || !_consent) return;

        _loading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/subscribe", request);
            if (response.IsSuccessStatusCode)
                _submitted = true;
            else
                _emailError = "Something went wrong — please try again.";
        }
        catch
        {
            _emailError = "Something went wrong — please try again.";
        }
        finally
        {
            _loading = false;
        }
    }
}
