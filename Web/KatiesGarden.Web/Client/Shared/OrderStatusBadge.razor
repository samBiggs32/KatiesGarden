@* Reusable badge for order status — used in customer portal and admin views *@

<span class="badge badge-sm @BadgeClass font-medium">@StatusLabel</span>

@code {
    [Parameter, EditorRequired] public OrderStatus Status { get; set; }

    private string BadgeClass => Status switch
    {
        OrderStatus.Pending              => "badge-ghost",
        OrderStatus.Confirmed            => "badge-info",
        OrderStatus.Processing           => "badge-warning",
        OrderStatus.ReadyForCollection   => "badge-success",
        OrderStatus.Dispatched           => "badge-primary",
        OrderStatus.Delivered            => "badge-success",
        OrderStatus.Cancelled            => "badge-error",
        OrderStatus.Refunded             => "badge-error badge-outline",
        _                                => "badge-ghost"
    };

    private string StatusLabel => Status switch
    {
        OrderStatus.ReadyForCollection   => "Ready to Collect",
        _                                => System.Text.RegularExpressions.Regex.Replace(Status.ToString(), @"(?<=[a-z])(?=[A-Z])", " ")
    };
}
