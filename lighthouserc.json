{
  "ci": {
    "collect": {
      "numberOfRuns": 2
    },
    "assert": {
      "assertions": {
        "categories:performance":     ["warn",  { "minScore": 0.60 }],
        "categories:accessibility":   ["error", { "minScore": 0.85 }],
        "categories:best-practices":  ["warn",  { "minScore": 0.85 }],
        "categories:seo":             ["warn",  { "minScore": 0.75 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
